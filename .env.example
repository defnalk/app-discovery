# Supabase (required for production; omit both + set LOCAL_STORE=1 for local dev)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Storage fallback: set to 1 to persist to data/local-store.json instead of Supabase
LOCAL_STORE=

# Apify (Google Play ingest, X scraper). Job skips itself politely if unset.
APIFY_TOKEN=
# Override the Play Store actor if needed (default: epctex/google-play-scraper)
APIFY_PLAY_ACTOR=

# Product Hunt GraphQL developer token. Job skips itself if unset.
PRODUCT_HUNT_TOKEN=

# Apollo.io API key for organization enrichment. Job skips itself if unset.
APOLLO_API_KEY=

# Optional shared token for the dashboard server (npm run serve).
# If set, requests must carry ?token=... once; a cookie keeps the session.
DASHBOARD_TOKEN=
